    "canvas": "^3.1.0",
    "concurrently": "^9.1.2",
    "cookie-session": "^2.1.0",
    "dompurify": "^3.2.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "lodash": "^4.17.21",
    "mongoose": "^8.13.2",
    "nodemon": "^3.1.9",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
